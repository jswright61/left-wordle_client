#!/usr/bin/env bash
set -euo pipefail

ENV=${1:-}
if [[ -z "$ENV" ]]; then
  echo "Usage: bin/deploy <staging|production> [vX.Y.Z]" >&2
  exit 1
fi

case "$ENV" in
  staging)    BRANCH="staging" ;;
  production) BRANCH="main" ;;
  *)
    echo "Unknown environment: $ENV (must be staging or production)" >&2
    exit 1
    ;;
esac

TAG=${2:-}

if [[ -n "$TAG" ]]; then
  if ! [[ "$TAG" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "Error: '$TAG' is not a valid version tag (expected vX.Y.Z)" >&2
    exit 1
  fi
  if ! git rev-parse --verify "refs/tags/$TAG" &>/dev/null; then
    echo "Error: tag '$TAG' does not exist" >&2
    exit 1
  fi
  VERSION="$TAG"

  echo "Deploying $VERSION → $ENV (pinned)"

  echo "→ Pushing $VERSION to paula..."
  git push paula "$VERSION"

  echo "→ Pushing $VERSION to origin (background)..."
  git push origin "$VERSION" &>/dev/null &
  disown $!
else
  VERSION=$(git tag --points-at "$BRANCH" | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -1)
  if [[ -z "$VERSION" ]]; then
    echo "Error: tip of '$BRANCH' has no semantic version tag." >&2
    echo "Tag the commit before deploying:" >&2
    echo "  git tag -a vX.Y.Z -m 'Release X.Y.Z' && git push paula vX.Y.Z" >&2
    exit 1
  fi

  echo "Deploying $VERSION → $ENV"

  echo "→ Pushing $BRANCH + tags to paula..."
  git push paula "$BRANCH" --tags

  echo "→ Pushing $BRANCH + tags to origin (background)..."
  git push origin "$BRANCH" --tags &>/dev/null &
  disown $!
fi

if [[ -n "$TAG" ]]; then
  cap_env=(env "DEPLOY_TAG=$VERSION")
else
  cap_env=()
fi

echo "→ cap $ENV deploy..."
"${cap_env[@]}" bundle exec cap "$ENV" deploy
